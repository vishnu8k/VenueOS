rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin access function
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /events/{eventId} {
      allow read: if true; // Public event details
      allow write: if isAdmin();
    }
    
    match /attendees/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin(); // Or cloud function
    }

    // Pings are write only from user
    match /gps_pings/{pingId} {
      allow create: if request.auth != null && request.resource.data.attendeeId == request.auth.uid;
      allow read: if isAdmin();
    }
    
    match /scan_events/{scanId} {
      allow create: if true; // In reality check staff JWT in security rules using custom token
      allow read: if isAdmin();
    }
    
    match /density_snapshots/{snapId} {
      allow read: if isAdmin();
    }
    
    match /incident_reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.attendeeId == request.auth.uid;
      allow read, update: if isAdmin();
    }
  }
}
